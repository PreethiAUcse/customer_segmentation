{
  "datasets": [
    {
      "name": "99278224",
      "displayName": "Untitled dataset",
      "queryLines": [
        "SELECT\n",
        "  Cluster_Name,\n",
        "  COUNT(*) AS customers\n",
        "FROM gold_customer_segments\n",
        "GROUP BY Cluster_Name\n",
        "ORDER BY customers DESC;"
      ]
    },
    {
      "name": "c37efcf2",
      "displayName": "Untitled dataset",
      "queryLines": [
        "SELECT\n",
        "  Cluster_Name,\n",
        "  COUNT(*) AS customers\n",
        "FROM gold_customer_segments\n",
        "GROUP BY Cluster_Name\n",
        "ORDER BY customers DESC;"
      ]
    },
    {
      "name": "5ec987c9",
      "displayName": "Untitled dataset",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) AS total_customers\n",
        "FROM gold_customer_segments;\n"
      ]
    },
    {
      "name": "cf6bf1fb",
      "displayName": "Untitled dataset",
      "queryLines": [
        "SELECT\n",
        "  ROUND(AVG(Lifetime_Value), 2) AS avg_ltv\n",
        "FROM gold_customer_segments;"
      ]
    },
    {
      "name": "37902e9f",
      "displayName": "Untitled dataset",
      "queryLines": [
        "SELECT\n",
        "  ROUND(SUM(Churned) / COUNT(*), 2) AS overall_churn_rate\n",
        "FROM gold_customer_segments;"
      ]
    },
    {
      "name": "2d1eb9e1",
      "displayName": "Untitled dataset",
      "queryLines": [
        "SELECT\n",
        "  Cluster_Name,\n",
        "  COUNT(*) AS customers\n",
        "FROM gold_customer_segments\n",
        "GROUP BY Cluster_Name\n",
        "ORDER BY customers DESC;"
      ]
    },
    {
      "name": "daf012ac",
      "displayName": "Untitled dataset",
      "queryLines": [
        "SELECT\n",
        "  Cluster_Name,\n",
        "  ROUND(AVG(Lifetime_Value), 2) AS avg_ltv\n",
        "FROM gold_customer_segments\n",
        "GROUP BY Cluster_Name\n",
        "ORDER BY avg_ltv DESC;"
      ]
    },
    {
      "name": "0cc4b43c",
      "displayName": "Untitled dataset",
      "queryLines": [
        "SELECT\n",
        "  Cluster_Name,\n",
        "  ROUND(SUM(Churned) * 100.0 / COUNT(*), 2) AS churn_rate\n",
        "FROM gold_customer_segments\n",
        "GROUP BY Cluster_Name\n",
        "ORDER BY churn_rate DESC;"
      ]
    },
    {
      "name": "7af8c8d5",
      "displayName": "Untitled dataset",
      "queryLines": [
        "SELECT\n",
        "  Cluster_Name,\n",
        "  ROUND(AVG(Total_Purchases), 2) AS avg_purchases,\n",
        "  ROUND(AVG(Average_Order_Value), 2) AS avg_order_value\n",
        "FROM gold_customer_segments\n",
        "GROUP BY Cluster_Name\n",
        "ORDER BY avg_purchases DESC;"
      ]
    },
    {
      "name": "d7fb068f",
      "displayName": "Untitled dataset",
      "queryLines": [
        "SELECT\n",
        "  Cluster_Name,\n",
        "  ROUND(AVG(Lifetime_Value), 2) AS avg_ltv\n",
        "FROM gold_customer_segments\n",
        "GROUP BY Cluster_Name\n",
        "ORDER BY avg_ltv DESC\n",
        "LIMIT 1;"
      ]
    }
  ],
